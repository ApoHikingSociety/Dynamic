local Service = "TWW Specials Service"
local Identifier = "1035442"
local Provider = "Dynamic"

local ScriptMap = {
    [807930589] = "https://api.jnkie.com/api/v1/luascripts/public/95e151e386456cebbb64a64a06a8faa80c7f3544fcd788a07b481e3f6ff975a8/download",
    [5130394318] = "https://api.jnkie.com/api/v1/luascripts/public/d111871052b43a2591b2e327ec470d79f3e2be75b5d0c682a2c0843a61c4533a/download"
}

local GameId = game.GameId
local ScriptUrl = ScriptMap[GameId]

if not ScriptUrl then
    return
end

local Junkie = loadstring(game:HttpGet("https://jnkie.com/sdk/library.lua"))()
Junkie.service = Service
Junkie.identifier = Identifier
Junkie.provider = Provider

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function GetExecutor()
    local Name = "Unknown"
    pcall(function()
        if identifyexecutor then
            Name = identifyexecutor()
        elseif getexecutorname then
            Name = getexecutorname()
        end
    end)
    return tostring(Name):lower()
end

local function IsExecutorBlocked()
    local Exec = GetExecutor()
    if string.find(Exec, "xeno") then
        return true
    end
    return false
end

local function IsKeyValid(Key)
    local Ok, Res = pcall(function()
        return Junkie.check_key(Key)
    end)
    if Ok and type(Res) == "table" then
        return true
    end
    return false
end

local function StartWatcher(Key)
    if getgenv()._DynamicKeyWatcher then
        return
    end

    getgenv()._DynamicKeyWatcher = true

    task.spawn(function()
        while task.wait(240) do
            pcall(function()
                Junkie.check_key(Key)
            end)
        end
    end)
end

local function LoadMain()
    loadstring(game:HttpGet(ScriptUrl))()
end

local Key = getgenv().SCRIPT_KEY

if Key and IsKeyValid(Key) then
    if IsExecutorBlocked() then
        LocalPlayer:Kick("Executor is not supported.")
        return
    end

    StartWatcher(Key)
    LoadMain()
end

local QueueOnTeleport = syn and syn.queue_on_teleport or queue_on_teleport

LocalPlayer.OnTeleport:Connect(function(State)
    if State == Enum.TeleportState.InProgress then
        QueueOnTeleport('getgenv().SCRIPT_KEY = "' .. tostring(Key or "") .. '" loadstring(game:HttpGet("https://raw.githubusercontent.com/ApoHikingSociety/Dynamic//main/Main"))()')
    end
end)
